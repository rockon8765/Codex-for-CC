{
  "_comment": "把這個 PreToolUse 條目合併進 ~/.claude/settings.json 的 hooks.PreToolUse。請把 hook 的絕對路徑改成你自己機器的路徑。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash|PowerShell|RemoteTrigger|PushNotification|CronCreate|CronDelete|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/user/.claude/hooks/super-mode-consult-gate.js"
          }
        ]
      }
    ]
  }
}
